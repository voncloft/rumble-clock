{
  "manifest_version": 3,
  "name": "Rumble Chat Clock",
  "version": "1.2.1",
  "description": "Shows a configurable live clock in the top-right corner of Rumble chat.",
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://rumble.com/chat*"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "action": {
    "default_title": "Rumble Chat Clock",
    "default_popup": "options.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "rumble-chat-clock@local"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://rumble.com/chat*"
      ],
      "js": [
        "clock-core.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
